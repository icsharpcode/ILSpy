<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="30"
             x:Class="ILSpy.MainToolBar">
	<StackPanel Orientation="Horizontal" Height="30">
		<!-- Navigation category (Back/Forward) inserted by MEF (task #10) -->
		<Separator />
		<!-- Open category inserted by MEF (task #10) -->
		<Separator />
		<!-- Assembly list combobox (task #6 / #11) -->
		<ComboBox Name="AssemblyListComboBox" Margin="2,0"
		          ToolTip.Tip="Select an assembly list" />
		<Separator />
		<!-- Language selector (task #8) -->
		<ComboBox Name="LanguageComboBox" Margin="2,0"
		          ToolTip.Tip="Select output language" />
	</StackPanel>
</UserControl>
